--- util/selectionUtil.py	(original, io_export_i3d 9.1.0)
+++ util/selectionUtil.py	(patched - Blender 5.1: selected_ids needs OUTLINER region)
@@ -329,14 +329,22 @@
 def getSelectedObjects(context):
     # get active object from outliner context
     # this also includes hidden objects like collision etc
-    for area in context.screen.areas:
-        if area.type == 'OUTLINER':
-            override = context.copy()
